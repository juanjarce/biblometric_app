@inproceedings{merged676,
  abstract = {In today's digital era, the rapid development of big data and artificial intelligence technology is profoundly changing the marketing pattern of enterprises. With the popularization of the Internet, the Internet of Things and other technologies, data has exploded, providing unprecedented rich resources for precision marketing. Consumer demand is increasingly personalized, diversified, traditional marketing model is difficult to accurately reach the target customers, making marketing efficiency is low, serious waste of resources. Therefore, the use of big data and artificial intelligence technology to achieve precision marketing has become the key for enterprises to stand out in the fierce market competition. This study aims to deeply explore how big data and artificial intelligence enable precision marketing, build a precision marketing model, analyze actual cases, and put forward corresponding strategy suggestions, so as to provide theoretical and practical guidance for enterprises to improve marketing efficiency and achieve accurate reach to consumers.},
