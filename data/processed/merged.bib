@inproceedings{merged635,
  abstract = {Artificial Intelligence Generated Content has been deeply researched from the aspects of “smart library construction”, “smart transformation of knowledge service”, “metaverse library construction”, “Artificial Intelligence Generated Content technology and service mode reform” in the Chinese library field. In order to summary the current development progress of Artificial Intelligence Generated Content in the Chinese library field and provide some reference for the future development of Artificial Intelligence Generated Content in the field of library. The paper comprehensively makes use of bibliometrics and data visualization technology to visualize and analyze the research papers on the application of Artificial Intelligence Generated Content in the Chinese library field from four aspects ( including “Analysis of the year of publication papers”, “Analysis of Literature Type”, “Analysis of Research Strengths” and “Analysis of the Research Hotspot” ), and looking forward to the future research content that needs to be strengthened in the Chinese library field of Artificial Intelligence Generated Content from two aspects( including “Strengthen literacy education of Artificial Intelligence Generated Content” and “Research on enhancing the deep integration of Artificial Intelligence Generated Content and library.” ).},
