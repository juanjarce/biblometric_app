  isbn = {9798400709968},
  keywords = {ChatGPT; Copilot; Generative AI; IT Professional; Software Engineering; Software Process; Survey},
  location = {Juiz de Fora, Brazil},
  numpages = {9},
  publisher = {Association for Computing Machinery},
  series = {SBSI '24},
  title = {Impacts of the Usage of Generative Artificial Intelligence on Software Development Process},
  url = {https://doi.org/10.1145/3658321.3658367},
  year = {2024}
}

