  doi = {10.1145/3745034.3745097},
  isbn = {9798400714399},
  keywords = {Artificial intelligence; Convolutional neural networks; Deep learning; Medical imaging analysis; Multimodal data fusion; Orthodontics; and traditional teaching mode; artificial intelligence; teaching effect; tumor imaging teaching},
