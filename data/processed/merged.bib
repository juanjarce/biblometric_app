@article{merged358,
  abstract = {Generative Artificial Intelligence (GAI) is fundamentally changing the ways of working and blurring the boundaries between human and machine-generated contents. While there is an increasing interest in the adoption of GAI systems, such as ChatGPT and DALL-E, there are also serious concerns about the copyright of the contents—the inputs or generated as outputs by the GAI systems. Such concerns need to be identified and assessed to ensure the ethical and responsible use of GAI systems. Thus, this article aims to address the key research challenge: “how to identify and assess GAI system's copyright concerns”? In response, we propose the development of a Copyright Risk Checker (CRC) Tool. This tool has been formulated and evaluated using a recognised design science research methodology, drawing on an analysis of 10 legal cases across Australia, the United Kingdom, the United States, and Europe. The CRC Tool has undergone evaluation through an experimental scenario, and the results suggest that it is suitable for conducting an indicative copyright risk check of GAI systems. The outcomes of this preliminary assessment can be further examined by expert legal advisors for an in-depth analysis. The development of the CRC Tool provides a foundation for continued research and advancement in this significant area of study.},
  address = {New York, NY, USA},
  articleno = {41},
  author = {Billiris, Grace and Gill, Asif and Oppermann, Ian and Niazi, Mahmood},
  doi = {10.1145/3703459},
  issue_date = {December 2024},
  journal = {Digit. Gov.: Res. Pract.},
  keywords = {Authorship; Copyright Concern; Copyright Regulations; GAI Governance; Generative Artificial Intelligence; Independent Intellectual Effort},
  month = {December},
  number = {4},
  numpages = {21},
  publisher = {Association for Computing Machinery},
  title = {Towards the Development of a Copyright Risk Checker Tool for Generative Artificial Intelligence Systems},
  url = {https://doi.org/10.1145/3703459},
  volume = {5},
  year = {2024}
}

@inproceedings{merged359,
  abstract = {This study investigated the students' perceptions of using Generative Artificial Intelligence (GenAI) in upper-secondary mathematics education. Data was collected from Finnish high school students to represent how key constructs of the Technology Acceptance Model—Perceived Usefulness, Perceived Ease of Use, Perceived Enjoyment, and Intention to Use—influence the adoption of AI tools. First, a structural equation model for a comparative study with a prior study was constructed and analyzed. Then, an extended model with the additional construct of Compatibility, which represents the alignment of AI tools with students' educational experiences and needs, was proposed and analyzed. The results demonstrated a strong influence of perceived usefulness on the intention to use GenAI, emphasizing the statistically significant role of perceived enjoyment in determining perceived usefulness and ease of use. The inclusion of compatibility improved the model's explanatory power, particularly in predicting perceived usefulness. This study contributes to a deeper understanding of how AI tools can be integrated into mathematics education and highlights key differences between the Finnish educational context and previous studies based on structural equation modeling.},
  address = {New York, NY, USA},
  author = {Set\"{a}l\"{a}, Mika and Heilala, Ville and Sikstr\"{o}m, Pieta and K\"{a}rkk\"{a}inen, Tommi},
  booktitle = {Proceedings of the 40th ACM/SIGAPP Symposium on Applied Computing},
  doi = {10.1145/3672608.3707817},
  isbn = {9798400706295},
  keywords = {generative artificial intelligence; mathematics education; technology acceptance; upper secondary school},
  location = {Catania International Airport, Catania, Italy},
  numpages = {10},
  pages = {74–82},
  publisher = {Association for Computing Machinery},
  series = {SAC '25},
  title = {The Use of Generative Artificial Intelligence for Upper Secondary Mathematics Education Through the Lens of Technology Acceptance},
  url = {https://doi.org/10.1145/3672608.3707817},
  year = {2025}
}

@inproceedings{merged360,
  abstract = {Generative artificial intelligence (GenAI), leveraging deep learning techniques such as neural networks, is revolutionizing education. This study explores the current research status, key areas, and emerging trends by analyzing 2,856 papers from 2014 to 2023 using CiteSpace software. Key findings reveal that: 1. The focus of GenAI research has shifted towards large language models, such as ChatGPT, especially since 2022. 2. Major research contributions come from China, the U.S., and South Korea, with China leading in institutional involvement. 3. Research trends indicate growing interest in AI applications for immersive education, deep learning models, and medical education. 4. Ethical considerations and data processing methodologies, including anomaly detection and data augmentation, are crucial emerging topics in the field. This paper outlines the most active research clusters and provides future directions for interdisciplinary applications and ethical AI.},
  address = {New York, NY, USA},
  author = {Han, Xiaotian},
  booktitle = {Proceedings of the 2024 8th International Conference on Algorithms, Computing and Systems},
  doi = {10.1145/3708597.3708606},
  isbn = {9798400718304},
  keywords = {Generative artificial intelligence 1; current research status 3; future educationn2; hot spots 4; research trends 5},
  numpages = {6},
  pages = {56–61},
  publisher = {Association for Computing Machinery},
  series = {ICACS '24},
  title = {Generative Artificial Intelligence for Future Education: Current Research Status, Hot Spots, and Research Trends},
  url = {https://doi.org/10.1145/3708597.3708606},
  year = {2025}
}

@inproceedings{merged361,
  abstract = {The Air Quality Index (AQI) is an effective measure of air quality, and accurate prediction of the AQI is important for air pollution control and the daily travel of people. Air pollutants have strong spatio-temporal correlation, and the current air quality prediction methods often fail to adequately extract the spatio-temporal features in the data, which can cause prediction accuracy problems. This paper proposed a Self-Tuning Spatio-Temporal Residual Network (AAM-AST2RN) fusing adaptive adjacency matrix and attention mechanism for enhanced air quality prediction. AAM-AST2RN utilized a parallel network structure, which was capable of fully extracting and fusing spatio-temporal features and automatically adjusting the network hyperparameters. In addition, the AAM-AST2RN model constructed the AAM generation module, residual connection and Improved Channel Attention mechanism (ICA), the AAM generation module avoided the adverse effect of static adjacency matrix on the model feature extraction, the residual connection and ICA effectively alleviated the node feature over-smoothing problem caused by Graph Convolutional neural Network (GCN) in the model and improved the node feature differentiation. In order to validate the model effect, the model was utilized to predict the AQI of 12 air monitoring sites in Beijing, and compared with the prediction effect of Convolutional Long Short-Term Memory neural network (ConvLSTM), combined Convolutional Neural Network and Long Short-Term Memory neural network (CNN-LSTM), and GCN-LSTM. Compared with the above three spatio-temporal prediction models, the coefficient of determination (R2) of the AAM-AST2RN model was improved by 11.30%, 1.95%, and 1.54%, respectively, and the prediction error was lower. The AAM-AST2RN air quality prediction model proposed in this paper can fully extract the spatio-temporal features in the data and has a good prediction performance for air quality.},
  address = {New York, NY, USA},
  author = {Tang, Pengchun and Wang, Zepei and Wang, Siqi and Zhu, Gareth and Wang, Jiaxin and Lang, Yuanhua and Shao, Wenjuan and Huang, Weiming and Yan, Shuang},
  booktitle = {Proceedings of the 2024 International Conference on Generative Artificial Intelligence and Information Security},
  doi = {10.1145/3665348.3665359},
  isbn = {9798400709562},
  keywords = {ARIMA-BP neural network; Complex network topology; GA Optimized BP Neural Network Prediction},
  location = {Kuala Lumpur, Malaysia},
  numpages = {10},
  pages = {380–387},
  publisher = {Association for Computing Machinery},
  series = {GAIIS '24},
  title = {Extracting features for enhanced air quality prediction: a self-tuning spatio-temporal residual network approach fusing adaptive adjacency matrix and attention mechanism},
  url = {https://doi.org/10.1145/3665348.3665359},
  year = {2024}
}

@inproceedings{merged362,
  abstract = {Improving undergraduate students' ability to cope with cyber risks is one of the key issues to be addressed in the digital transformation of higher education in the era of generative artificial intelligence. In order to explore how to improve undergraduate students' ability to cope with information security threats brought about by generative artificial intelligence, this paper constructs a theoretical model for improving undergraduate students' information security behaviour in the context of generative artificial intelligence by integrating the theory of protective motivation, the theory of planned behaviour, and the theory of social cognition. Based on 354 questionnaire survey data, this study systematically analyses the influencing factors and mechanisms of undergraduate students' information security in the context of generative artificial intelligence. The results show that perceived threat, subjective norms and self-efficacy have a positive influence on students' information security behaviour intention, which in turn has a positive influence on their information security behaviour implementation, with environmental support playing a moderating role between the two. The findings of the study help to further improve the theoretical model of undergraduate students' information security behaviour in the context of artificial intelligence, and at the same time provide valuable insights for education departments and colleges and universities to take effective measures to improve undergraduate students' information security capabilities in the era of generating artificial intelligence.},
  address = {New York, NY, USA},
  author = {Cao, Yuhua},
  booktitle = {Proceedings of the 2025 4th International Conference on Cryptography, Network Security and Communication Technology},
  doi = {10.1145/3723890.3723902},
  isbn = {9798400712623},
  keywords = {Generative Artificial Intelligence; Information Security Behavior; Undergraduate Students},
  numpages = {6},
  pages = {69–74},
  publisher = {Association for Computing Machinery},
  series = {CNSCT '25},
  title = {Research on the Mechanism for Enhancing Undergraduate Students' Information Security Behavior in the Context of Generative Artificial Intelligence},
  url = {https://doi.org/10.1145/3723890.3723902},
  year = {2025}
}

@inproceedings{merged363,
  abstract = {With the recent rapid rise in Generative Artificial Intelligence (GAI) tools, it is imperative that we understand their impact on people with disabilities, both positive and negative. However, although we know that AI in general poses both risks and opportunities for people with disabilities, little is known specifically about GAI in particular. To address this, we conducted a three-month autoethnography of our use of GAI to meet personal and professional needs as a team of researchers with and without disabilities. Our findings demonstrate a wide variety of potential accessibility-related uses for GAI while also highlighting concerns around verifiability, training data, ableism, and false promises.},
