@inproceedings{merged469,
  abstract = {This paper explores the application of Generative Artificial Intelligence (GenAI) techniques to the design of Role Playing Games (RPGs) in Extended Reality (XR) environments. We developed the game Reborn of the White Bone Demon, which utilizes AI speech emotion recognition technology to generate story lines and game assets in real-time based on the player’s conversations with NPCs, enhancing the player’s immersion and personalized experience, demonstrating the potential of GenAI in enhancing the XR gaming experience.},
