@article{merged605,
  abstract = {Artificial intelligence is changing our world. The arrival of ChatGPT in 2022 brought AI into the public spotlight with a dramatic new capability. A user can how engage in a fluent conversation in ordinary language with a computer. Suddenly many people want to know what AI is, whether it is safe, and what benefits it might bring. Artificial intelligence is defined to be a collection of machines and algorithms that perform tasks normally considered to require human cognition. Opinions and claims about the possible benefits and risks of AI are all over the map. In response to the confusion, the Ubiquity editors are launching a symposium on AI. It will be a series of about two dozen articles on the many aspects of AI and its applications. The series will be synthesized into the "Ubiquity Report on Artificial Intelligence," which is intended to be an authoritative and trustworthy summary of present and future AI.},
  address = {New York, NY, USA},
  articleno = {1},
  author = {Johnson, Jeff and Denning, Peter J.},
  doi = {10.1145/3747352},
  issue_date = {July 2025},
  journal = {Ubiquity},
  month = {July},
  number = {July},
  numpages = {5},
  publisher = {Association for Computing Machinery},
  title = {Artificial Intelligence: Introducing the ACM Ubiquity Symposium on Artificial Intelligence},
  url = {https://doi.org/10.1145/3747352},
  volume = {2025},
  year = {2025}
}

@inproceedings{merged606,
  abstract = {Recent advances in diffusion-based generative models have shown incredible promise for zero shot image-to-image translation and editing. Most of these approaches work by combining or replacing network-specific features used in the generation of new images with those taken from the inversion of some guide image. Methods of this type are considered the current state-of-the-art in training-free approaches, but have some notable limitations: they tend to be costly in runtime and memory, and often depend on deterministic sampling that limits variation in generated results. We propose Filter-Guided Diffusion (FGD), an alternative approach that leverages fast filtering operations during the diffusion process to support finer control over the strength and frequencies of guidance and can work with non-deterministic samplers to produce greater variety. With its efficiency, FGD can be sampled over multiple seeds and hyperparameters in less time than a single run of other SOTA methods to produce superior results based on structural and semantic metrics. We conduct extensive quantitative and qualitative experiments to evaluate the performance of FGD in translation tasks and also demonstrate its potential in localized editing when used with masks.},
  address = {New York, NY, USA},
  articleno = {101},
  author = {Gu, Zeqi and Yang, Ethan and Davis, Abe},
  booktitle = {ACM SIGGRAPH 2024 Conference Papers},
  doi = {10.1145/3641519.3657489},
  isbn = {9798400705250},
  keywords = {Diffusion Models; Generative Artificial Intelligence; Image Synthesis; Style Transfer},
  location = {Denver, CO, USA},
  numpages = {10},
  publisher = {Association for Computing Machinery},
  series = {SIGGRAPH '24},
  title = {Filter-Guided Diffusion for Controllable Image Generation},
  url = {https://doi.org/10.1145/3641519.3657489},
  year = {2024}
}

