  title = {Fashion Forward: Exploring the Influence of AI on Modern Fashion Trends},
  volume = {7},
  year = {2024}
}

@inproceedings{merged339,
  abstract = {Generative Artificial Intelligence (GenAI) chatbots start changing experiences with art for museum visitors by making them more interactive and engaging. However, it remains underexplored how GenAI chatbots influence visitors’ in-field experience and interaction at art museums regarding finding information, engagement, and enjoyment compared to existing museum tour-guide applications. In this paper, we contribute the design and implementation of a smartphone-based chatbot that detects artwork, generates textual and auditory information, and interactively answers visitors’ questions. To explore visitors’ experience with it, we conducted a field experiment (N=30) at the National Art Museum, comparing it to the existing museum application. Our results indicate that visitors showed higher artwork engagement with the chatbot than the museum application. Moreover, they enjoyed an interactive experience using the chatbot to learn about the art collection and have equally preferred textual and auditory information representation.},
  address = {New York, NY, USA},
  author = {Wang, Huan and Matviienko, Andrii},
  booktitle = {Proceedings of the 2025 ACM International Conference on Interactive Media Experiences},
  doi = {10.1145/3706370.3731650},
  isbn = {9798400713910},
  keywords = {Chatbot; Generative AI; Museum experience; Tour guide},
  numpages = {7},
  pages = {430–436},
  publisher = {Association for Computing Machinery},
  series = {IMX '25},
  title = {Experiencing Art Museum with a Generative Artificial Intelligence Chatbot},
  url = {https://doi.org/10.1145/3706370.3731650},
  year = {2025}
}

@inproceedings{merged340,
  abstract = {Driven by artificial intelligence, human-computer interaction system design is evolving towards intelligence, automation, and diversification. OBJECTIVE: The objective of this study is to systematically present the progress of human-computer interaction design research in the AI era over the past 20 years. In order to achieve this, the study firstly highlights the current state of development, trends and current research hotspots. It then provides a reference for further research. METHODS: Using visualisation tools such as CiteSpace, VOSviewer, and Scimago Graphica, this study analysed 887 documents included in the Web of Science database from 2004 to 2024, covering knowledge mapping in terms of countries, author institutions, keywords, etc., in order to comprehensively grasp the research dynamics of HCISD of the AI model. The results show that the development of the research field of HCISD in the context of artificial intelligence shows a steady growth trend; the issuing countries are spread all over the world, mainly concentrated in economically developed countries with strong scientific research strength; the current research hot spots are concentrated in four main aspects of intelligent innovation system, intelligent interconnected management, intelligent technical task, and intelligent technical interaction; the future development trend tends to promote user experience through advanced visual expression; and the future trend tends to enhance user experience, promote collaboration, and provide richer information interaction through advanced visual expression and interaction technologies. Conclusion: Research in human-computer interaction design follows the rapid development of artificial intelligence technologies and continuously explores new theoretical and practical approaches to meet the increasing demand for intelligent systems.},
