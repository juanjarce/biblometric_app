@inproceedings{merged336,
  abstract = {Soil nutrients have a significant contribution in the health of soil and in productivity of crops. However, traditional methods of analysis of different parameters of soil such as electrical conductivity (EC), pH, organic carbon, moisture content, nitrogen, C/N ratio, phosphorus and potassium (NPK) and soil temperature are time consuming and exhaustive methods. However, with advancement in artificial intelligence, various advanced and digital based techniques can be explored for handling the large number of soil parameters data for better and efficient results. A set of AI techniques including Deep Learning (DL) and Machine Learning (ML) have great potential in advanced technology based agriculture systems. Farmers and soil scientists can identify the amount of nutrients present in agricultural soil by exploiting AI methods particularly ML and DL techniques. These techniques are accurate and adaptable techniques. Accuracy of results can be achieved by ML technique. Generative AI, a subset of AI is playing an important role to enhance the productivity in agriculture domain. In this paper, the authors have shown the application of GAN, a machine learning framework, to generate data that imitates real soil contamination data. This synthetic data can help to augment training datasets for machine learning models.},
  author = {Jabin, Shagufta and Abbas, Sadiqa and Chadha, Anupama and Chawla, Jyoti},
  booktitle = {2024 2nd International Conference on Advances in Computation, Communication and Information Technology (ICAICCIT)},
  doi = {10.1109/ICAICCIT64383.2024.10912319},
  keywords = {Accuracy; Agriculture; Artificial intelligence; Contamination; Data models; Deep Learning; Deep learning; GAN; Generative AI; Generative adversarial networks; Machine Learning; Nutrients; Productivity; Soil},
  month = {Nov},
  pages = {337-341},
  title = {Application of Artificial Intelligence in Soil Contamination Analysis: Green Sustainable Practices},
  volume = {1},
  year = {2024}
}

@inproceedings{merged337,
  abstract = {Generative Artificial Intelligence (GAI) has revolutionized higher education with features like instant feedback, resource and material creation, adaptive learning, interactivity, and more. However, GAI also brings with it a number of serious challenges that raise ethical and moral concerns regarding academic integrity. To carry out this transition process, it will be necessary to develop clear guidelines that adhere to integrity standards and ethical codes of higher education institutions. In addition to offering responses to a number of research questions, the purpose of this study is to further the current discourse surrounding the moral guidelines for GAI in higher education. Using the Preferred Reporting Items for Systematic Reviews and Meta-Analyses (PRISMA) technique and Bibliometric Analysis using VOSviewer, 37 related research studies were reviewed and evaluated. The results demonstrate that the number of articles published has been increasing over time, with the largest number of scientific publications occurring in 2024. This can be explained by the fact that, despite the fact that GAI offers benefits and drawbacks for the educational sector, particularly for higher education, it also makes clear how important it is for professionals and organizations to use GAI tools in order to handle ethical issues by continuously developing policies. By creating norms and policies, future ethical problems with GAI in education may be more accurately predicted. The engagement and dedication of academic experts and other relevant stakeholders are essential to achieving this goal of increasing public awareness and effectively utilizing GAI technology.},
  author = {Arista, Artika and Shuib, Liyana and Ismail, Maizatul Akmar},
  booktitle = {2024 International Conference on Informatics, Multimedia, Cyber and Information System (ICIMCIS)},
  doi = {10.1109/ICIMCIS63449.2024.10956736},
  issn = {2837-5203},
  keywords = {Bibliometric Analysis; Bibliometrics; Education; Ethical Policies; Ethics; Generative AI; Generative Artificial Intelligence (GAI); Guidelines; Higher Education Institutions (HEIs); Multimedia databases; Organizations; Stakeholders; Standards organizations; Systematic Literature Review; Systematic literature review},
  month = {Nov},
  pages = {454-459},
  title = {Systematic Literature Review and Bibliometric Analysis on Ethical Policies for Generative Artificial Intelligence (GAI) in Higher Education Institutions (HEIs)},
  year = {2024}
}

@inproceedings{merged338,
  abstract = {Fashion has always been a forward-thinking phenomenon that adopts new technology as they become available. Fashion includes design, manufacturing, and consumption, all of which rely on technology to increase product quality and availability in retailers. Artificial intelligence moves as fast as fashion. For almost a decade, artificial intelligence has been utilized to analyse consumer preferences and fashion trends. Its influence on fashion, including the advent of the Fast Fashion movement, is clear. As the garment sector’s digitalization moves toward industry 5.0, the application of artificial intelligence will become more frequent in a wider range of processes. This study will investigate the uses of artificial intelligence in the fashion and business sectors. This research will look into the applications of artificial intelligence in the fashion and business sectors. The paper will also cover modern AI models used in the fashion industry, such as Generative Adversarial Networks (GAN), StyleGAN, StyleGAN2, and Variational Autoencoders (VAEs).},
