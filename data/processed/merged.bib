  keywords = {Algorithmic governance; Artificial Intelligence; Artificial intelligence; Bibliometric analysis; DDoS Attack; Machine Learning; Public policy; artificial intelligence; evaluation; f1000; logistics; open peer review; scholar influence; supply chain},
  numpages = {6},
