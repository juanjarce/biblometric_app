@article{merged617,
  abstract = {Artificial intelligence (AI) integration into education has received significant global attention, sparking a need for comprehensive regulatory frameworks for governance. In this commentary, we first examine the role of AI in education and how it is integrated with the teaching and learning process. It also discusses the impact of AI on higher education through specific case studies and tries to illuminate the current/emerging trends, challenges, and potential future directions. Furthermore, it highlights insights from global initiatives, policy frameworks, and ethical standards adopted by prominent organizations to govern AI in higher education. The study concludes that the optimal use of these AI apps can only be harnessed through proper transparency and ethical balance.},
  address = {New York, NY, USA},
  articleno = {20},
  author = {Mahrishi, Mehul and Abbas, Asad and Siddiqui, Mohammad Khubeb},
  doi = {10.1145/3672462},
