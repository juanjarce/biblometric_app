@inproceedings{merged668,
  abstract = {Artificial intelligence (AI) is a subdiscipline of computer science, broadly speaking, usually refers to some computer program that can collect valid information from large amounts of data and perform some specific tasks of the developer. The goal is to develop new types of devices or programs that can recognize, analyze, and diagnose as humans do. The initial application of artificial intelligence (AI) was in the field of medical imaging for the automatic detection of lung nodules in X-ray and computed tomography (CT) techniques. Malignant pulmonary nodules are often associated with primary lung tumors and metastatic lung lesions, so the screening, diagnosis and differentiation of pulmonary nodules are very important for the subsequent treatment of lung diseases.},
