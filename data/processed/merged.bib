  doi = {10.1145/3628516.3659404},
  isbn = {9798400704420},
  keywords = {Artificial Intelligence; Bias; Child-Computer Interaction; Digital Story Telling; Ethics; Generative AI},
  location = {Delft, Netherlands},
  numpages = {5},
