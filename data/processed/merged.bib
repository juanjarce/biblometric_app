  booktitle = {2025 8th International Conference on Artificial Intelligence and Big Data (ICAIBD)},
  doi = {10.1109/ICAIBD64986.2025.11081956},
  issn = {2769-3554},
  keywords = {AI Education; Artificial Intelligence (AI) Literacy; Artificial intelligence; Bibliometric Analysis; Bibliometrics; Big Data; Buildings; Clustering; Cognition; Data governance; Data models; Data visualization; Education; Generative AI; Libraries; Regulation; Reviews; Systematics; data governance; generative AI; lifecycle; risk},
