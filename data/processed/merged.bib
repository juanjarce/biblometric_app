  title = {Observation on the application effect of artificial intelligence-assisted teaching mode in tumor imaging teaching},
  url = {https://doi.org/10.1145/3745034.3745097},
  year = {2025}
}

@inproceedings{merged640,
  abstract = {In the 21st century, the rapid development of computers and the Internet has facilitated the deep integration of art and technology, leading to the vigorous rise of new media art and making immersive experiences a new trend in the cultural and creative industries. This research uses Nanjing, a representative example of urban culture, as a backdrop to explore immersive visual image design and examine the impact of integrating technology and art on the cultural and creative industries. First, deep learning algorithms, including Convolutional Neural Networks (CNNs), are employed to automatically analyze Nanjing's urban culture and extract visual elements, such as mountains, water, cities, and forests, with local characteristics. Next, Generative Adversarial Networks (GANs) are used to generate and optimize the extracted visual elements, organizing them in a systematic manner to enhance the artistic and scientific qualities of the images. Additionally, a highly interactive imaging system is designed by combining ToughDesigner (TD) software with Kinect sensing equipment. Finally, an immersive visual exhibition space is constructed using light and shadow projection technology to showcase Nanjing's urban culture and shape the city's image. This research aims to provide a reference for the future development of new media art, promote the deeper integration of technology and art, and enhance the public's cultural experience and perception of artworks.},
  address = {New York, NY, USA},
  author = {Chen, Shuang and Chen, Huan and Lu, Yajun},
  booktitle = {Proceedings of the 2024 7th International Conference on Computer Information Science and Artificial Intelligence},
  doi = {10.1145/3703187.3703227},
  isbn = {9798400707254},
  keywords = {Artificial intelligence; Artificial intelligence technology; Ethical governance; Executives' academic background; Green technology innovation; Immersive visual image; Information security; Interactive virtual simulation; Nanjing city culture; People-oriented},
  numpages = {6},
  pages = {238–243},
  publisher = {Association for Computing Machinery},
  series = {CISAI '24},
  title = {Can the application of artificial intelligence technology promote enterprise green technology innovation?},
  url = {https://doi.org/10.1145/3703187.3703227},
  year = {2024}
}

@inproceedings{merged641,
  abstract = {The continuous development of social media in scientific communication and the arrival of the era of artificial intelligence have provided more possibilities for evaluating the influence of scholars, making evaluation algorithms no longer limited to quantitative indicators. On the basis of existing scholars' influence evaluation algorithms at home and abroad, this article designs a scholar influence evaluation approach and algorithm based on open peer review. That is, the qualitative content of open peer review in scholar articles is processed by certain artificial intelligence technology to form multiple label sets that can represent the influence of scholars from different dimensions, thus exploring the multi angle evaluation of scholar influence from a quality perspective. Finally, this article conducts empirical research and comparative analysis on the effectiveness of the proposed algorithm using the open peer review platform F1000 as the data source platform. Empirical research has shown that the algorithm proposed in this article provides a new perspective and approach for evaluating the influence of scholars, which can preliminarily achieve multidimensional evaluation of scholars, endow scholars with personal academic profiles, and enhance the fullness and recognition of scholar influence. Comparative analysis shows that this algorithm does not have a significant correlation with bibliometric evaluation algorithms and can serve as a supplement to the existing evaluation system. The combination of traditional bibliometric analysis algorithms and open peer review based algorithms will be the future development trend of academic evaluation.},
  address = {New York, NY, USA},
  author = {Kou, Jingjing and Yuan, Guohua},
  booktitle = {Proceedings of the 2024 4th International Conference on Big Data, Artificial Intelligence and Risk Management},
  doi = {10.1145/3718751.3718856},
