  isbn = {9798400711732},
  keywords = {Art; Artificial Intelligence; ChatGPT; Classification algorithms; Design teaching; Digital education; Education; Generative AI; Generative artificial intelligence; International Chinese Education; Learning (artificial intelligence); Support vector machines; Teaching Resources; Transforms},
  month = {Jan},
  numpages = {5},
  pages = {165-169},
  publisher = {Association for Computing Machinery},
  series = {ICIEAI '24},
  title = {A Comparative Study of Artificial Intelligence-Enabled Business Foreign Language Teaching in Universities: Taking ChatGPT-4o, Claude3.5 Sonnet and ERNIE 4.0 Turbo as Examples},
