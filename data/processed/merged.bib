  pages = {39–42},
  publisher = {Association for Computing Machinery},
  title = {Toward Privacy-Preserving Training of Generative AI Models for Network Traffic Classification},
  url = {https://doi.org/10.1145/3725536.3725540},
  volume = {52},
  year = {2025}
}

