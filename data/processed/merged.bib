  doi = {10.1145/3716554.3716589},
  isbn = {9798400713170},
  keywords = {Artificial Intelligence; Dynamic Demand Forecasting; Machine Learning; Sales Prediction},
  numpages = {6},
  pages = {231–236},
  publisher = {Association for Computing Machinery},
  series = {PCI '24},
  title = {A real world case study on sales prediction using Artificial Intelligence},
  url = {https://doi.org/10.1145/3716554.3716589},
  year = {2025}
}

@inproceedings{merged673,
  abstract = {This study evaluates the consistency between an AI system and traditional doctor diagnoses in detecting heart sound abnormalities, and explores the impact of noise reduction technology on AI performance in noisy environments. Methods: Stage 1: AI and doctor diagnoses were compared in detecting single and multiple heart sound abnormalities using a deep neural network (DNN) model. Performance was measured by Cohen's Kappa, sensitivity, specificity, and F1 score. Stage 2: Noise reduction technology was applied to assess its effect on AI performance in high-noise environments, using frequency-domain filtering, CNNs, and metrics like the Noise Impact Index (NII) and Noise Reduction Rate (NRR). Results: In Stage 1, the AI showed high consistency with doctors for single abnormalities (Cohen's Kappa = 0.81), but underperformed for multiple abnormalities. It achieved 96% sensitivity, 93% specificity, and an F1 score of 0.89, though performance was affected by noise. In Stage 2, noise reduction significantly improved AI accuracy, particularly in detecting multiple abnormalities, where AI outperformed doctors. Conclusion: The AI system demonstrated strong agreement with doctors, especially in detecting single abnormalities. Noise reduction technology enhanced its diagnostic accuracy and stability, particularly in complex environments. Further optimization is needed for more comprehensive performance in diverse cases.},
  address = {New York, NY, USA},
  author = {Sung, Jinghui and Jiang, Zikang and Chang, Yun-Chen and Huang, Yuanpeng and Chen, Ting-Yu},
  booktitle = {Proceedings of the 2024 4th International Symposium on Big Data and Artificial Intelligence},
  doi = {10.1145/3723366.3723384},
  isbn = {9798400718298},
  keywords = {Artificial Intelligence; Big Data; Computer; Diagnostic Consistency; Heart Sound Abnormality Detection; Methods and Models; Noise Reduction},
  numpages = {8},
  pages = {113–120},
  publisher = {Association for Computing Machinery},
  series = {ISBDAI '24},
  title = {Diagnostic Testing Analysis of Digital Stethoscopes Based on Artificial Intelligence and Noise Reduction Technology},
  url = {https://doi.org/10.1145/3723366.3723384},
  year = {2025}
}

@inproceedings{merged674,
  abstract = {Sport events are conducted throughout the world for several reasons. The host city and country are benefited by improving economic, cultural, and other benefits. Modern sport events have taken place with Artificial Intelligence (AI) effectively. AI technologies are used to enhance the productivity and fan involvement. The performance of athletes is also improved using AI. This work presents the detailed summary of the applications of AI in sports events management. The underlying technologies in AI such as machine learning (ML), computer vision (CV), and big data analytics (BDA) acts as a key factor in sport events. AI techniques can be used to predict match results and health monitoring. The sport event is facilitated with effective scheduling and resource management using AI. AI techniques are also used to prepare the training plans based on user needs. It can be used to improve the skills of athletes. The use of Virtual Reality (VR) and AI are able to enhance viewing experience of sports events. The challenges associated with AI-based sports events were discussed. The comparative analysis of machine learning (ML) and deep learning (DL) models were presented. The results indicated that DL-based methods increase performance.},
