  isbn = {9798400717055},
  keywords = {Artificial Intelligence; Artificial intelligence; Brain modeling; ChatGPT; Companies; Computer security; Disaster Management; FinTech; Fraud Detection; Generative AI; Human-made Disaster; Industries; Large Learning Module; Machine Learning; Natural disaster; PLS-SEM; Protection; Regulation; Risk Management; SIEM; Shape; Stakeholders; Training; education; generative AI; programming},
  location = {Bali Island, Indonesia},
  month = {Oct},
  numpages = {6},
