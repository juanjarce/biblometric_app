  year = {2025}
}

@inproceedings{merged643,
  abstract = {We are concurrently witnessing two significant shifts: voice and chat-based conversational user interfaces (CUIs) are becoming ubiquitous (especially more recently due to advances in generative AI and LLMs - large language models), and older people are becoming a very large demographic group (and increasingly adopting of mobile technology on which such interfaces are present). However, despite the recent increase in research activity, age-relevant and inter/cross-generational aspects continue to be underrepresented in both research and commercial product design. Therefore, the overarching aim of this workshop is to increase the momentum for research within the space of hands-free, mobile, and conversational interfaces that centers on age-relevant and inter- and cross-generational interaction. For this, we plan to create an interdisciplinary space that brings together researchers, designers, practitioners, and users, to discuss and share challenges, principles, and strategies for designing such interfaces across the life span. We thus welcome contributions of empirical studies, theories, design, and evaluation of hands-free, mobile, and conversational interfaces designed with aging in mind (e.g. older adults or inter/cross-generational). We particularly encourage contributions focused on leveraging recent advances in generative AI or LLMs. Through this, we aim to grow the community of CUI researchers across disciplinary boundaries (human-computer interaction, voice and language technologies, geronto-technologies, information studies, etc.) that are engaged in the shared goal of ensuring that the aging dimension is appropriately incorporated in mobile / conversational interaction design research.},
  address = {New York, NY, USA},
  articleno = {37},
  author = {Munteanu, Cosmin and Sarcar, Sayan and Sin, Jaisie and Ziying Wei, Christina and Sayago, Sergio and Zhao, Wei and Waycott, Jenny and Boostani, Rezvan and Ghafurian, Moojan and Getson, Cristina},
  booktitle = {Proceedings of the 7th ACM Conference on Conversational User Interfaces},
  doi = {10.1145/3719160.3728626},
  isbn = {9798400715273},
  numpages = {5},
  publisher = {Association for Computing Machinery},
  series = {CUI '25},
  title = {Designing Age-Inclusive Interfaces: Emerging Conversational and Generative AI to Support Interactions across the Life Span},
  url = {https://doi.org/10.1145/3719160.3728626},
  year = {2025}
}

@inproceedings{merged644,
  abstract = {Audio-visual speech synthesis (AVSS) is a rapidly gaining prominence in artificial intelligence (AI) due to its widespread applications. AVSS refers to generating the audio-visual speech of a target speaker from the audio input of a source speaker, while preserving the speech content. The sequential steps of the AVSS process include voice conversion (VC) for altering vocal characteristics from the source to the target speaker and audio-visual synthesis (AVS) to generate a video stream from the converted speech of the target speaker. However, with the progressive development of deep generative models, the domain of AVSS remains relatively unexplored. The existing literature predominantly focuses on autoencoder-based AVSS models, potentially limiting their ability to capture the diversity of the vocal features and also synthesize the realistic video output. This paper introduces a novel AVSS approach utilizing a generative adversarial network (GAN) model, enriched with a capsule network (Caps-Net) architecture to effectively capture relevant input speech features and produce more natural audio-visual output. The proposed framework is trained and tested on VoxCeleb2 and LRS3-TED datasets and the experimental outcomes exhibit the superiority of the proposed approach over the state-of-the-art (SOTA) models.},
  address = {New York, NY, USA},
  author = {Ghosh, Subhayu and Jana, Nanda Dulal},
  booktitle = {Proceedings of the 8th International Conference on Data Science and Management of Data (12th ACM IKDD CODS and 30th COMAD)},
  doi = {10.1145/3703323.3703325},
  isbn = {9798400711244},
  keywords = {Audio-Visual Speech Synthesis (AVSS); Audio-Visual Synthesis (AVS); Capsule Network (Caps-Net).; Generative Adversarial Network (GAN); Voice Conversion (VC)},
  numpages = {9},
  pages = {10–18},
  publisher = {Association for Computing Machinery},
  series = {CODS-COMAD '24},
  title = {Audio-Visual Speech Synthesis Leveraging Capsule-Enhanced Generative Adversarial Network},
  url = {https://doi.org/10.1145/3703323.3703325},
  year = {2025}
}

@article{merged645,
  abstract = {Generative AI has the potential to transform how public services are delivered by enhancing productivity and reducing time spent on bureaucracy. But to what extent is the technology already in use? Our survey of UK public service professionals (in education, health, social work, and emergency services) seeks to answer this question. We find that use of generative AI is widespread: 45% of respondents were aware of colleagues using generative AI, while 22% use it themselves. Respondents were positive about its potential to enhance their efficiency and reduce their bureaucratic workload. For example, those working in the health service thought that time spent on bureaucracy could drop by the equivalent of one day per week, an enormous potential impact. Our survey also found a high amount of trust (61%) in generative AI and a low fear of replacement (16%). However, only a minority of respondents (32%) felt like there was clear guidance on generative AI usage in their workplaces. In other words, it is clear that generative AI is already coming into the public sector, but uptake is happening in a disorganised fashion without clear guidelines. The UK’s public sector urgently needs to develop more systematic methods for taking advantage of the technology.},
  address = {New York, NY, USA},
  articleno = {2},
  author = {Bright, Jonathan and Enock, Florence and Esnaashari, Saba and Francis, John and Hashem, Youmna and Morgan, Deborah},
  doi = {10.1145/3700140},
  issue_date = {March 2025},
  journal = {Digit. Gov.: Res. Pract.},
  keywords = {Bureaucracy; Generative AI; Productivity; Public Sector},
  month = {February},
  number = {1},
  numpages = {13},
  publisher = {Association for Computing Machinery},
  title = {Generative AI is already widespread in the public sector: evidence from a survey of UK public sector professionals},
  url = {https://doi.org/10.1145/3700140},
  volume = {6},
  year = {2025}
}

@article{merged646,
  abstract = {Image generative AI (IGAI) could change how policymakers engage with the public to design public spaces, facilitating how designers translate the public’s desires into features. However, using IGAI has challenges, such as encoded biases, which might reinforce stereotypes and harm underrepresented communities. We conducted a case study to explore how using IGAI alters the co-design process of public parks through public engagement. We use data collected from interviews with immigrants discussing the Puente Hills Landfill Park design in Los Angeles, which will re-purpose a former landfill into a new public park. We use Dream Studio as a Design Probe, generating images from the interviewees’ insights and critically reflecting on the design process through internal interviews and a reflective workshop. We analyze our case in three domains: Opportunities, Risks and Challenges, and Features and Requirements. In the opportunities domain, we discuss how the enhanced translation of words to images changes the relationship between stakeholder engagement, multiplicity, and efficiency. In the risks and challenges domain, we discuss how IGAI might enhance power imbalances and biases. Finally, we reflect on what features would ease the safe and responsible use of IGAI to engage citizens in co-designing public parks.},
  address = {New York, NY, USA},
  articleno = {7},
  author = {Guridi, Jose A. and Cheyre, Cristobal and Goula, Maria and Santo, Duarte and Humphreys, Lee and Souras, Achilleas and Shankar, Aishwarya},
  doi = {10.1145/3656588},
  issue_date = {March 2025},
  journal = {Digit. Gov.: Res. Pract.},
  keywords = {Image-generative AI; design; landscape architecture; public spaces},
  month = {February},
  number = {1},
  numpages = {14},
  publisher = {Association for Computing Machinery},
  title = {Image Generative AI to Design Public Spaces: a Reflection of How AI Could Improve Co-Design of Public Parks},
  url = {https://doi.org/10.1145/3656588},
  volume = {6},
  year = {2025}
}

@inproceedings{merged647,
  abstract = {This paper explores the ethical implications of integrating Artificial Intelligence (AI) in educational settings, from primary schools to universities, while drawing insights from ancient Greek philosophy to address emerging concerns. As AI technologies increasingly influence learning environments, they offer novel opportunities for personalized learning, efficient assessment, and data-driven decision-making. However, these advancements also raise critical ethical questions regarding data privacy, algorithmic bias, student autonomy, and the changing roles of educators. This research examines specific use cases of AI in education, analyzing both their potential benefits and drawbacks. By revisiting the philosophical principles of ancient Greek thinkers such as Socrates, Aristotle, and Plato, we discuss how their writings can guide the ethical implementation of AI in modern education. The paper argues that while AI presents significant challenges, a balanced approach informed by classical philosophical thought can lead to an ethically sound transformation of education. It emphasizes the evolving role of teachers as facilitators and the importance of fostering student initiative in AI-rich environments.},
  address = {New York, NY, USA},
  articleno = {57},
  author = {Nicolae, Irina E. and Danciu, Gabriel and Nanou, Christina and Koulierakis, Nikolaos and Danilatou, Vasiliki},
  booktitle = {Proceedings of the 13th Hellenic Conference on Artificial Intelligence},
  doi = {10.1145/3688671.3688772},
  isbn = {9798400709821},
  keywords = {Artificial Intelligence; Autonomy; Education; Ethical AI; Ethics; Explainability; Explainable AI (XAI); Explicability; Healthcare; Philosophy; Teaching; Transparency Metrics},
  numpages = {7},
  publisher = {Association for Computing Machinery},
  series = {SETN '24},
  title = {Artificial Intelligence in Education: Ethical Considerations and Insights from Ancient Greek Philosophy},
  url = {https://doi.org/10.1145/3688671.3688772},
  year = {2024}
}

@inproceedings{merged648,
  abstract = {The swift growth of industrial urban areas urgently calls for a shift from conventional to intelligent urban centers. In this context, transportation emerges as a primary entry point and fundamental pillar for this transformation, poised to revolutionize urban management and service models. To uncover the evolutionary trends of urban transportation systems in the age of artificial intelligence, this paper utilizes the Web of Science core database as its retrieval source, employing tools such as Citespace 6.2R6 and Vosviewer for visual analysis of the retrieved literature. The research findings indicate that the overall number of publications in this field has shown an upward trend from 2005 to 2024, passing through three stages: emergence, exploration, and stabilization. China stands out as the leading force in this research domain, with ZHANG J identified as a key author exerting significant influence. The research hotspots converge around four themes: intelligent transportation management, deep intelligent models, intelligent transportation systems(ITS) and smart transportation frameworks. In summary, ITS have witnessed substantial development, and their role in future urban transportation management is set to become increasingly important. With continuous technological advancements and sustained policy support, it is anticipated that ITS will achieve broader applications and deeper research in the coming years.},
  address = {New York, NY, USA},
  author = {Deng, Tingyin and Jiang, Xuemei and Wang, Meiling and Luo, Jingwen},
  booktitle = {Proceedings of the 2024 3rd International Conference on Artificial Intelligence and Intelligent Information Processing},
  doi = {10.1145/3707292.3707372},
  isbn = {9798400707308},
  keywords = {Artificial Intelligence (AI); Citespace; Traditional painting; Urban Transport Systems (UTS); Vosviewer; style transfer; traditional culture},
  numpages = {7},
  pages = {241–247},
  publisher = {Association for Computing Machinery},
  series = {AIIIP '24},
  title = {Analysis of the Research Status and Development Trend of Urban Transportation System in the Era of Artificial Intelligence},
  url = {https://doi.org/10.1145/3707292.3707372},
  year = {2025}
}

@inproceedings{merged649,
  abstract = {The development of artificial intelligence (AI) in the beauty industry can reshape the way consumers interact with businesses, enabling them to quickly select more suitable products and providing a more convenient, targeted, and safer comfortable experience. Cosmetics companies integrate AI technology with offline shopping models, not only enhancing customer engagement and novelty in the store but also allowing businesses to identify products that customers prefer and target. South Korea is the first country in the world to enact laws and policies related to the customized cosmetics industry. South Korea's use of AI technology to develop customized cosmetics has been widely noticed in the international beauty market. The AI technology-based customized cosmetics industry in South Korea is mainly composed of three major industries: cosmetic products (skin care, makeup, beauty and hair care, and related products), beauty devices, and software services. In 2015, after Amorepacific Group first developed customized cosmetics in South Korea, companies such as LG Household &amp; Health Care Ltd, CJ On Style, and H&amp;B began to engage in research and development in the customized cosmetics industry, achieving good results in both technology and product development. This study collects and investigates the development strategies of South Korean customized cosmetics companies and analyzes and organizes the methods of use and production principles of related products. It is hoped to provide some reference value for the development strategies and product research and development of global AI customized cosmetics companies.},
  address = {New York, NY, USA},
  author = {Jiang, Jinyi and Wu, Enpeng and Miao, Zihan},
  booktitle = {Proceedings of the 5th International Conference on Artificial Intelligence and Computer Engineering},
  doi = {10.1145/3716895.3716981},
  isbn = {9798400718007},
  keywords = {Artificial Intelligence; Artificial Intelligence (AI); Bayesian Network; Customized Cosmetics; Digital Economy; Intelligent Transformation; South Korean AI Cosmetics Enterprise; Traditional Manufacturing},
  numpages = {4},
  pages = {485–488},
  publisher = {Association for Computing Machinery},
  series = {ICAICE '24},
  title = {Application of Artificial Intelligence Technology in the Digital Transformation Path of Traditional Manufacturing Based on Bayesian Network},
  url = {https://doi.org/10.1145/3716895.3716981},
  year = {2025}
}

@inproceedings{merged650,
  abstract = {The global ultra-wide display market is growing rapidly due to widespread consumer adoption. However, existing content, especially on TV screens, is mainly designed for lower aspect ratios like 4:3. As TVs shift towards wider formats, there’s a need to develop a method to transform legacy content and adapt to varying screen sizes. This shift holds the potential to revolutionize the content viewing experience for gamers, content creators, and streaming enthusiasts. While delivering high-quality visual content for dynamic aspect ratios remains a challenge, recent advancements in Deep Learning show promise in addressing these problems with generative approaches. Our contribution begins with a survey of prior video completion efforts, providing a foundational backdrop. We then introduce our novel solution, combining optical flow methodologies with generative latent diffusion models. These models, conditioned on an initial prompt and evolving video frame, refine content generation. We validate our approach on the DAVIS dataset, demonstrating its efficacy and robustness. In summary, our study pioneers advancements in content generation for ultra-wide displays.},
  address = {New York, NY, USA},
  author = {Palczewski, Tomasz Jan and Rao, Anirudh and Zhu, Yingnan},
  booktitle = {Proceedings of the 2024 16th International Conference on Machine Learning and Computing},
  doi = {10.1145/3651671.3651681},
  isbn = {9798400709234},
  keywords = {Gen-AI; aspect ratio enhancement; neural enhancement; optical-flow},
  location = {Shenzhen, China},
  numpages = {8},
  pages = {355–362},
  publisher = {Association for Computing Machinery},
  series = {ICMLC '24},
  title = {Generative-AI- and Optical-Flow-Based Aspect Ratio Enhancement of Videos},
  url = {https://doi.org/10.1145/3651671.3651681},
  year = {2024}
}

@inproceedings{merged651,
  abstract = {The era of digital economy has arrived. This article aims to explore the role, significance and application of artificial intelligence in the framework of digital economy, and how they can create synergistic effects through interaction. On the one hand, artificial intelligence promotes the development of digital economy; On the other hand, the digital economy provides broad application scenarios and development space for artificial intelligence. This interactive relationship enables the two to empower each other and develop together. From the core components of artificial intelligence, this paper analyzes the characteristics of productivity and production relations in the era of digital economy. On this basis, the synergistic relationship between artificial intelligence and digital economy, future development trends, key technologies and applications in different industries are deeply studied. In one word, the relationship between artificial intelligence and the digital economy is an interdependent and mutually reinforcing relationship. As the core driving force of the digital economy, artificial intelligence promotes the sustainable development of the digital economy; The digital economy provides broad application scenarios and development space for artificial intelligence. With the continuous advancement of technology and the expansion of application scenarios, the integration between artificial intelligence and digital economy will deepen, jointly promoting social progress and development. Therefore, this paper can provide some support for the in-depth development and exploration research of artificial intelligence in digital economy era.},
  address = {New York, NY, USA},
  author = {Yang, Sihan and Wang, Meiyao},
