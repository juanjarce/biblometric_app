  keywords = {Artificial intelligence; Cognition; Computational modeling; Computers; Counterfactual Explanations; Explainable Artificial Intelligence; Hardware; Machine learning algorithms; Robot sensing systems; Service robots; Software; Software algorithms; and Users},
  month = {June},
  number = {4},
  numpages = {37},
  pages = {27-49},
  publisher = {Association for Computing Machinery},
