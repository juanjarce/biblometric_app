  pages = {106–112},
  publisher = {Association for Computing Machinery},
  series = {FAIML '24},
  title = {Improving Artificial Intelligence Translation Ability Based on Attention Mechanism and Layer Jumping Connection},
  url = {https://doi.org/10.1145/3653644.3653656},
  year = {2024}
}

@inproceedings{merged663,
  abstract = {The remote illegal login of attackers has been a headache for many legitimate users in recent years. We use the tamper-proof property of blockchain and the convenience of artificial intelligence to develop an identity authentication system with multiple login methods in this paper. The system uses the dual authentication scheme which combines local verification public and private keys with user identity public and private keys, combined with face recognition and verification of public and private keys, so as to judge the legitimacy of user identity. The system provides a variety of login methods, with friendly interface, easy operation and high security features, can be used as the first security gate of important information systems.},
  address = {New York, NY, USA},
  author = {Xiao, Linghao and Zhao, Ling and Xue, Jingyuan and Li, Shufei and Li, Wanyu and Dou, Zilong and Nie, Zhongyao},
